# --- Credenciais de Login da Aplicação ---
APP_USER=seu_usuario_aqui
APP_PASS=sua_senha_aqui

# --- Google Gemini API (opcional) ---
# Usada para geração de análise por IA no relatório PDF.
# Obtenha sua chave em: https://aistudio.google.com/app/apikey
# Deixe em branco para usar análise por regras locais (sem IA).
GEMINI_API_KEY=
